# =============================================================================
# Planly Organizer — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# See setup_guide.md for instructions on obtaining each credential.
# =============================================================================

# Database URL (SQLite default for local development)
DATABASE_URL=sqlite:///planly_organizer.db

# Google Gemini API key (used for AI summarization)
GEMINI_API_KEY=

# Canvas LMS API token (used for course data)
CANVAS_API_TOKEN=
CANVAS_BASE_URL=https://canvas.ucsc.edu

# Microsoft Azure AD App ID (used for Outlook and OneDrive)
# NOTE: This is a public identifier (not a secret). For reviewers, you can use
# the default client id below. For production use, consider creating your own
# Entra app registration.
MICROSOFT_APP_ID=edf0be76-049c-4130-aa48-cad3cd75a2c9

# Google OAuth credentials are stored in credentials.json (not env vars).
# Google service account key is stored in ServiceAccountToken.json (not env vars).

# Demo mode: returns fixture data so the app works without connecting accounts.
DEMO_MODE=false
